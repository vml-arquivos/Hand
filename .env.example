# Database
DATABASE_URL=postgresql://rifas:troque_esta_senha_do_banco@localhost:5432/rifas

# Node Environment
NODE_ENV=development
PORT=3000

# Admin Bootstrap (primeira execução apenas)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=SenhaSegura123!@#
ADMIN_NAME=Super Admin

# JWT Secret (MUDE ISSO EM PRODUÇÃO - mínimo 32 caracteres)
JWT_SECRET=troque_este_segredo_jwt_com_mais_de_32_caracteres_em_producao

# Database Migrations
DB_MIGRATION_ATTEMPTS=30
DB_MIGRATION_DELAY_MS=2000

# Application Title
VITE_APP_TITLE=Sistema de Rifas Beneficentes

# Upload Directory (local storage)
UPLOAD_DIR=/app/uploads
PUBLIC_UPLOAD_BASE_URL=/uploads

# OAuth (se usar)
OWNER_OPEN_ID=seu_open_id_aqui

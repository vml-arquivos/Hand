# Copie estas variáveis para a área Environment Variables do Coolify.
# Troque as senhas antes de publicar.

NODE_ENV=production
PORT=3000
VITE_APP_TITLE=Sistema de Rifas Beneficentes
UPLOAD_DIR=/app/uploads
PUBLIC_UPLOAD_BASE_URL=/uploads

# Banco PostgreSQL 17 criado no Coolify.
# Se usar o docker-compose.yml deste repositório, pode manter o host como postgres.
POSTGRES_DB=rifas
POSTGRES_USER=rifas
POSTGRES_PASSWORD=troque_esta_senha_do_banco
DATABASE_URL=postgresql://rifas:troque_esta_senha_do_banco@postgres:5432/rifas

# Senha para entrar no painel /admin.
ADMIN_EMAIL=admin@admin.com
ADMIN_NAME=Administrador
ADMIN_PASSWORD=troque_esta_senha_do_admin

# Texto aleatório longo para segurança de sessão. Use pelo menos 32 caracteres.
JWT_SECRET=troque_este_segredo_jwt_com_mais_de_32_caracteres

# O app tenta preparar as tabelas automaticamente na primeira inicialização.
DB_MIGRATION_ATTEMPTS=30
DB_MIGRATION_DELAY_MS=2000
